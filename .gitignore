# Dependencies
/vendor/
/node_modules/

# Environment / secrets
/.env
/.env.*
!/.env.example
/.env.backup*

# Certificates / private keys
*.pem
*.p12
*.pfx
*.jks
*.keystore
id_rsa
id_rsa.pub
id_dsa
id_dsa.pub

# Service account / local auth artifacts
*service-account*.json
.envrc

# Runtime / cache / logs
/bootstrap/cache/*.php
!/bootstrap/cache/.gitignore
/public/hot
/public/storage
/public/build
/storage/*.key
/storage/pail
/storage/backup/*
/storage/install.zip
/storage/update.zip
/storage/logs/*.log

# Laravel framework runtime artifacts
/storage/framework/cache/data/*
!/storage/framework/cache/data/.gitignore
/storage/framework/sessions/*
!/storage/framework/sessions/.gitignore
/storage/framework/testing/*
!/storage/framework/testing/.gitignore
/storage/framework/views/*
!/storage/framework/views/.gitignore
/storage/debugbar/*
!/storage/debugbar/.gitignore

# Local database files
*.sqlite
*.sql
*.dump

# Local tooling
/.vagrant/
/.idea/
/.vscode/
Homestead.yaml
Homestead.json
docker-compose.override.yml

# PHP / JS tooling caches
/.phpunit.result.cache
/.phpunit.cache/
/.phpstan.cache/
/.php-cs-fixer.cache
/.phpactor.json
/coverage/
npm-debug.log
yarn-error.log

# Project-specific
/Modules/Gateways
database_backup_*
auth.json
error_log

# OS files
.DS_Store
storage/.DS_Store